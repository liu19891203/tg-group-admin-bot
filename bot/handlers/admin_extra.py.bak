async def show_schedule_list_menu(update, context, state: dict):
    del context
    group_id = _group_id(state)
    items = load_schedule_items(group_id)
    lines = ["鈴?鍏ㄩ儴瀹氭椂娑堟伅", ""]
    rows = []
    if not items:
        lines.append("鏆傛棤瀹氭椂娑堟伅銆?)
    else:
        for idx, item in enumerate(items):
            interval_min = max(1, int(item.get("interval_sec", 0) or 0) // 60)
            next_at = int(item.get("next_at", 0) or 0)
            next_text = time.strftime("%m-%d %H:%M", time.localtime(next_at)) if next_at > 0 else "鏈畨鎺?
            preview = _escape(_preview(item.get("text", ""), "(浠呭浘鐗?鎸夐挳)", 24))
            photo_flag = "鏈夊浘" if item.get("photo_file_id") else "鏃犲浘"
            button_count = len(item.get("buttons", []) or [])
            lines.append(f"{idx + 1}. {_checked(item.get('enabled', True))} {preview}")
            lines.append(f"   姣?{interval_min} 鍒嗛挓锛屼笅娆?{next_text}")
            lines.append(f"   {photo_flag} / 鎸夐挳 {button_count} 涓?)
            rows.append([_btn("缂栬緫娑堟伅", f"adminx:schedule:edit:{idx}"), _btn("鍚敤/鍋滅敤", f"adminx:schedule:toggle:{idx}")])
            rows.append([_btn("鍒犻櫎", f"adminx:schedule:delete:{idx}")])
    rows.append([_btn("杩斿洖", "adminx:schedule:menu")])
    await _send_or_edit(update, "\n".join(lines), InlineKeyboardMarkup(rows))



# Shared: required for both bot-worker and admin-web
BOT_TOKEN=your_telegram_bot_token
ADMIN_USER_ID=your_telegram_user_id
KV_REST_API_URL=https://your-upstash-rest-url
KV_REST_API_TOKEN=your-upstash-rest-token

# admin-web only: recommended for deployed web admin
WEB_SESSION_SECRET=replace_with_a_random_secret
WEB_COOKIE_SECURE=1
# Optional but recommended for Render/ClawCloud polling deployments:
# used when the bot wants to generate deep links back to the web admin
# WEB_APP_URL=https://your-admin-domain/web

# Webhook-only deployment (for example Vercel): set this only when using api/telegram.
# Do not set it for polling_worker.py or combined_service.py deployments.
# WEBHOOK_SECRET=replace_with_a_webhook_secret

# Optional runtime overrides
# WEB_SESSION_MAX_AGE_SEC=604800
# BOT_STORAGE_NAMESPACE=your_bot_namespace

# Local-only polling helper:
# local_polling.py will restore the previous webhook on exit.
# For long-running cloud workers, use polling_worker.py instead.

# Local debug only: do not set in production
# WEB_LOCAL_DEBUG_LOGIN_ENABLED=1
# WEB_LOCAL_DEBUG_LOGIN_SECRET=replace_with_a_local_secret
# LOCAL_KV_PATH=.local_kv.json
# BOT_ENV_FILE=.env
